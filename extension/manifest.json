{
  "manifest_version": 3,
  "name": "CourtCall Draw Importer",
  "version": "1.0.0",
  "description": "Scrape draws from ti.tournamentsoftware.com and import them straight into your CourtCall admin.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://ti.tournamentsoftware.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.up.railway.app/*",
    "https://*.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CourtCall Draw Importer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
